{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "cookiebite": ["./src/index.ts"],
      "cookiebite/themes": ["./src/themes.ts"]
    }
  },
  "include": ["src", "test/fixtures", "templates"],
  "exclude": [
    "test/fixtures/bad-type.tsx",
    "test/fixtures/bad-color.tsx",
    "test/fixtures/bad-css.tsx",
    "test/fixtures/empty-glossary.tsx",
    "test/fixtures/not-report.tsx"
  ]
}
